# Copy to .env.local for local dev.

NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional: with API `CAMPAIGN_FOLLOWUP_DELAY_UNIT=minutes`, set this so the Schedule step shows minutes + 1–120 range.
# NEXT_PUBLIC_CAMPAIGN_FOLLOWUP_DELAY_UNIT=minutes

# Stripe.js (Checkout / Elements). Optional until you enable card checkout in the UI.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
